# Frontend runtime API
VITE_API_BASE_URL=https://your-backend-service.onrender.com

# Firebase client config (if used in frontend)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Smart contract (testnet/mainnet deployed address)
VITE_CONTRACT_ADDRESS=0xYourDeployedContractAddress
VITE_DEFAULT_CONTRACT_ADDRESS=0xYourDeployedContractAddress

# Local-only flags (set false for Render)
VITE_USE_HARDHAT=false
